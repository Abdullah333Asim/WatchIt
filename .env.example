# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL=""

# TMDB_API_KEY: Required to fetch real movies from The Movie Database.
# Get a free API key at https://www.themoviedb.org/
TMDB_API_KEY=""

# GROQ_API_KEY: Optional. Used as a faster alternative/fallback for AI generation.
GROQ_API_KEY=""

# CEREBRAS_API_KEY: Optional. Another fast AI generation alternative.
CEREBRAS_API_KEY=""
